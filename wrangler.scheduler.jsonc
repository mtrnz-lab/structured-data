{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "structured-data-scheduler",
  "main": "./workers/scheduler.mjs",
  "compatibility_date": "2026-04-21",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "structured-data-monitor",
      "database_id": "e1a98be4-7580-40ac-8775-cb04ac8ffa43"
    }
  ],
  "vars": {
    "BROWSER_RUN_API_BASE": "https://api.cloudflare.com/client/v4",
    "MONITOR_CHECK_TIMEOUT_MS": "45000",
    "MONITOR_BATCH_LIMIT": "25"
  },
  "triggers": {
    "crons": [
      "0 6 * * *"
    ]
  }
}
